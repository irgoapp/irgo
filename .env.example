# Configuración del Servidor
PORT=3005
NODE_ENV=production

# Supabase (Tu base de datos y autenticación central)
SUPABASE_URL=https://tu-proyecto.supabase.co
# IMPORTANTE: Al estar en el backend, debes usar el SERVICE_ROLE_KEY o una key segura, 
# ya que este backend actuará con privilegios elevados en nombre de las APKs.
SUPABASE_SERVICE_KEY=eyJh...

# Meta WhatsApp API (Para bots y notificaciones)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/TU_NUMERO_ID/messages
WHATSAPP_ACCESS_TOKEN=EAAB...

# Mapas / Ruteo (Tu mapa propietario, OSRM, Google Maps, etc.)
# Aquí el backend calculará el precio antes de mandarlo al cliente
MAPS_API_URL=https://tu-servidor-rutas.com/api
MAPS_API_KEY=tu_api_key_secreta
